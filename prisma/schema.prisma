generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  username        String?      @unique
  firstName       String?
  lastName        String?
  password        String
  role            Role         @default(USER)
  emailVerified   DateTime? 
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  strategies      Strategy[]
  articles        Article[]
  topics          ForumTopic[]
  replies         ForumReply[]
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String   
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

model Broker {
  id            String   @id @default(uuid())
  name          String
  logoUrl       String?
  websiteUrl    String
  affiliateLink String
  rating        String   
  description   String   @db.Text 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Strategy {
  id             String   @id @default(uuid())
  title          String
  content        String   @db.Text
  imageUrl       String?
  difficulty     String   @default("Beginner")
  seoTitle       String?  
  seoDescription String?  @db.Text
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Article {
  id             String   @id @default(uuid())
  title          String
  content        String   @db.Text
  imageUrl       String?
  category       String   @default("General")
  seoTitle       String?  
  seoDescription String?  @db.Text
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ForumTopic {
  id        String       @id @default(uuid())
  title     String
  content   String       @db.Text
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   ForumReply[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ForumReply {
  id        String     @id @default(cuid())
  content   String     @db.Text
  topicId   String
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime     @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Settings {
  id              String   @id @default(uuid())
  riskDisclaimer  String   @db.Text
  telegramChannel String   @default("https://t.me/forexm_ax")
  telegramSupport String   @default("@Nanobotai")
  updatedAt       DateTime @updatedAt
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  identifier String   
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Settings {
  id              String   @id @default(uuid())
  riskDisclaimer  String   @db.Text
  telegramChannel String   @default("https://t.me/forexm_ax")
  telegramSupport String   @default("@Nanobotai")
  updatedAt        DateTime @updatedAt
}
model PasswordResetToken {
  id         String   @id @default(cuid())
  identifier String   // User's email
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}
